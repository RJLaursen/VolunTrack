<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MyRegistrationsController"
            prefWidth="800" prefHeight="450">
    <children>
        <VBox spacing="10" alignment="CENTER" prefWidth="800" prefHeight="450">
            <Label text="My Registrations" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TableView fx:id="regTable" prefWidth="760" prefHeight="340">
                <columns>
                    <TableColumn fx:id="idCol" text="Reg ID" prefWidth="70"/>
                    <TableColumn fx:id="projectCol" text="Project" prefWidth="150"/>
                    <TableColumn fx:id="locationCol" text="Location" prefWidth="120"/>
                    <TableColumn fx:id="dayCol" text="Day" prefWidth="80"/>
                    <TableColumn fx:id="slotsCol" text="Slots" prefWidth="70"/>
                    <TableColumn fx:id="hoursCol" text="Hours" prefWidth="70"/>
                    <TableColumn fx:id="contributionCol" text="Contribution" prefWidth="100"/>
                    <TableColumn fx:id="dateCol" text="Confirmed At" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Back to Dashboard" onAction="#goBack"/>
                <Button text="Cancel Registration" onAction="#cancelRegistration"/>
                <Button text="Export to CSV" onAction="#exportToCSV"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
