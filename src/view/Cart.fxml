<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.CartController"
            prefWidth="650" prefHeight="420">
    <children>
        <VBox spacing="12" alignment="CENTER" prefWidth="650" prefHeight="420" style="-fx-padding: 15;">
            <Label text="Registration Cart" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TableView fx:id="cartTable" prefWidth="600" prefHeight="250">
                <columns>
                    <TableColumn fx:id="titleCol" text="Title" prefWidth="150"/>
                    <TableColumn fx:id="dayCol" text="Day" prefWidth="100"/>
                    <TableColumn fx:id="slotsCol" text="Slots" prefWidth="80"/>
                    <TableColumn fx:id="hoursCol" text="Hours" prefWidth="80"/>
                    <TableColumn fx:id="valueCol" text="Hourly Value" prefWidth="100"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Remove Selected" onAction="#removeSelected"/>
                <Button text="Back to Dashboard" onAction="#goBack"/>
            </HBox>

            <Separator prefWidth="550"/>

            <Label fx:id="codeLabel" text="Your confirmation code is: (not generated yet)"
                   style="-fx-font-size: 12px; -fx-text-fill: gray;"/>
            <TextField fx:id="codeField" promptText="Enter confirmation code (6 digits)" prefWidth="250"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Generate Code" onAction="#generateCode"/>
                <Button text="Confirm Registration" onAction="#confirmRegistration"/>
            </HBox>

            <Label fx:id="messageLabel" style="-fx-font-weight: bold;"/>
        </VBox>
    </children>
</AnchorPane>
