<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.UpdatePasswordController"
            prefWidth="420" prefHeight="380">
    <children>
        <VBox spacing="10" alignment="CENTER" layoutX="50" layoutY="20" prefWidth="320">
            <Label text="Update Password" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <HBox spacing="5" alignment="CENTER">
                <PasswordField fx:id="oldPasswordField" promptText="Old Password" prefWidth="220"/>
                <TextField fx:id="visibleOldPasswordField" promptText="Old Password"
                           prefWidth="220" visible="false" managed="false"/>
                <Button fx:id="toggleOldPasswordBtn" text="👁" onAction="#toggleOldPasswordVisibility"/>
            </HBox>

            <HBox spacing="5" alignment="CENTER">
                <PasswordField fx:id="newPasswordField" promptText="New Password" prefWidth="220"/>
                <TextField fx:id="visibleNewPasswordField" promptText="New Password"
                           prefWidth="220" visible="false" managed="false"/>
                <Button fx:id="toggleNewPasswordBtn" text="👁" onAction="#toggleNewPasswordVisibility"/>
            </HBox>

            <HBox spacing="5" alignment="CENTER">
                <PasswordField fx:id="confirmPasswordField" promptText="Confirm New Password" prefWidth="220"/>
                <TextField fx:id="visibleConfirmPasswordField" promptText="Confirm New Password"
                           prefWidth="220" visible="false" managed="false"/>
                <Button fx:id="toggleConfirmPasswordBtn" text="👁" onAction="#toggleConfirmPasswordVisibility"/>
            </HBox>

            <Label text="New password must be at least 8 characters long, include an uppercase letter, a number, and a special character."
                   style="-fx-font-size: 11px; -fx-text-fill: #666;"
                   wrapText="true" maxWidth="280"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Update" onAction="#handleUpdate"/>
                <Button text="Back" onAction="#goBack"/>
            </HBox>

            <Label fx:id="messageLabel"
                   wrapText="true"
                   maxWidth="Infinity"
                   style="-fx-font-weight: bold; -fx-font-size: 12px;"/>
        </VBox>
    </children>
</AnchorPane>
