<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.LoginController"
            prefWidth="400" prefHeight="250">
    <children>
        <VBox spacing="10" alignment="CENTER" layoutX="50" layoutY="30" prefWidth="300">
            <Label text="VolunTrack Login" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            
            <TextField fx:id="usernameField" promptText="Username"/>
            <PasswordField fx:id="passwordField" promptText="Password"/>
            
            <Button text="Login" onAction="#handleLogin"/>
            <Button text="Signup" onAction="#goToSignup"/>
            
            <Label fx:id="messageLabel" textFill="red"/>
        </VBox>
    </children>
</AnchorPane>
