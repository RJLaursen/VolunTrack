<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.LoginController"
            prefWidth="400" prefHeight="300">
    <children>
        <VBox spacing="10" alignment="CENTER" layoutX="50" layoutY="20" prefWidth="300">
            <Label text="Login to VolunTrack" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <TextField fx:id="usernameField" promptText="Username"/>

            <HBox spacing="5" alignment="CENTER">
                <PasswordField fx:id="passwordField" promptText="Password" prefWidth="220"/>
                <TextField fx:id="visiblePasswordField" promptText="Password" prefWidth="220" visible="false" managed="false"/>
                <Button fx:id="togglePasswordBtn" text="👁" onAction="#togglePasswordVisibility"/>
            </HBox>

            <Button text="Login" onAction="#handleLogin"/>
            <Button text="Create Account" onAction="#goToSignup"/>

            <Label fx:id="messageLabel" style="-fx-font-weight: bold;"/>
        </VBox>
    </children>
</AnchorPane>
